<%- include('../../partials/header'); %>
<%- include('../../partials/navbar'); %>
<div class="container">
    <hr>
    <h2>Seila</h2>
    <hr>
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nome</th>
                <th>Carga Horária</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            <% courses.forEach((course) => {%>
                <tr>
                    <td><%= course.id %></td>
                    <td><%= course.nome %></td>
                    <td><%= course.cargaHoraria %></td>
                    <td>
                        <form //botar style="display: inline;">
                            <button class="btn btn-warning">Editar</button>
                        </form>
                        <form method="post" action="/courses/delete" style="display: inline;" onsubmit="confirmDelete(event, this)"> 
                            <input type="hidden" name="id" value="<%= course.id %>">
                             <button class="btn btn-danger">Deletar</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <a class="btn btn-success" href="/admin/courses/new">Criar novo curso</a>
</div>
<%- include('../../partials/footer'); %>

<script>
    function confirmDelete(event, form){
        event.preventDefault();
        var decision = confirm("Deseja deletar esta lista?")
        if (decision) {
            form.submit();
        }
    }
</script>