<%- include('../../partials/header'); %>
<%- include('../../partials/navbar'); %>
<div class="container">
    <hr>
    <h2>Students</h2>
    <hr>
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Date of Birth</th>
                <th>Actions</th>
                <th>Password</th>
                <th>Phone</th>
                <th>Certified</th>
            </tr>
        </thead>
        <tbody>
            <% students.forEach((student) => {%>
                <tr>
                    <td><%= student.id %></td>
                    <td><%= student.name %></td>
                    <td><%= student.email %></td>
                    <td><%= student.dateBirth %></td>
                    <td><%= student.password %></td>
                    <td><%= student.phone %></td>
                    <td><%= student.certified %></td>
                    <td>
                        <form //botar style="display: inline;">
                            <a href="/admin/students/edit/<%= student.id %>" class="btn btn-warning">Edit</a>
                        </form>
                        <form method="post" action="/students/delete" style="display: inline;" onsubmit="confirmDelete(event, this)"> 
                            <input type="hidden" name="id" value="<%= student.id %>">
                             <button class="btn btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <a class="btn btn-success" href="/admin/students/new">Create new student</a>
</div>
<%- include('../../partials/footer'); %>

<script>
    function confirmDelete(event, form){
        event.preventDefault();
        var decision = confirm("Do you want to delete this student?")
        if (decision) {
            form.submit();
        }
    }
</script>